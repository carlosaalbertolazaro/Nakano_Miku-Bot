# Copiá este archivo a .env y completá los valores reales. Nunca subas .env al repo.

NODE_ENV=production

# --- Módulo de IA (.ai / .miku) — key gratis en console.groq.com ---
GROQ_API_KEY=

# --- Servidor de Minecraft (Aternos) — comando .aternos + aviso cuando se prende ---
# Poné solo el host (el mismo que escribís en el cliente de Minecraft para conectarte),
# ej: chafacraft-Twzs.aternos.me — el puerto casi nunca hace falta, se resuelve
# solo vía el registro SRV de Aternos (que además cambia cada vez que reinicia el server).
ATERNOS_SERVER_HOST=
ATERNOS_SERVER_PORT=

# El fork de Baileys que usamos (github:itsliaaa/baileys) declara jimp@^1.6.1
# como peer dependency opcional, pero el proyecto usa jimp@^0.22.12 a propósito
# (ver nota en package.json / README). No usamos las funciones de baileys que
# dependen de ese peer, así que ignoramos el conflicto en vez de migrar a
# Jimp v1 (rewrite completo de API, alto riesgo sin poder testear en vivo).
legacy-peer-deps=true
